    <item>
      <title>My AFL-Elo model</title>
      <link>lazappi.id.au/post/2018-04-21-my-afl-elo-model/</link>
      <pubDate>Sat, 21 Apr 2018 00:00:00 +0000</pubDate>
      <guid>lazappi.id.au/post/2018-04-21-my-afl-elo-model/</guid>
      <description>&lt;!-- ```{r knitr, include = FALSE}
